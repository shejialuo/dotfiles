return {
  {
    "Exafunction/windsurf.nvim",
    event = { "BufReadPre", "BufNewFile" },
    dependencies = {
      "nvim-lua/plenary.nvim",
    },
    config = function()
      require("codeium").setup({
        enable_cmp_source = false,
        enable_chat = true,
        virtual_text = {
          enabled = true,
          manual = false,
          filetypes = {
            ["markdown"] = false,
            ["codecompanion"] = false,
          },
          key_bindings = {
            -- Accept the current completion.
            accept = "<C-l>",
            -- Accept the next word.
            accept_word = false,
            -- Accept the next line.
            accept_line = false,
            -- Clear the virtual text.
            clear = false,
            -- Cycle to the next completion.
            next = "<M-]>",
            -- Cycle to the previous completion.
            prev = "<M-[>",
          }
        },
      })
      vim.api.nvim_set_hl(0, "CodeiumSuggestion", { link = "Comment" })
      vim.api.nvim_create_autocmd("ColorScheme", {
        pattern = "*",
        callback = function()
            vim.api.nvim_set_hl(0, "CodeiumSuggestion", { link = "Comment" })
        end,
      })
    end,
    keys = {
      { "<leader>uz", "<cmd>Codeium Toggle<cr>", desc = "Toggle WindSurf"  }
    }
  },
  {
    "olimorris/codecompanion.nvim",
    cmd = {
      "CodeCompanion",
      "CodeCompanionChat",
      "CodeCompanionCLI",
    },
    keys = {
      {
        "<leader>aa", "<cmd>CodeCompanionActions<cr>",
        mode = { "n", "v" }, desc = "CodeCompanion Actions",
      },
      {
        "<leader>an", "<cmd>CodeCompanionChat<cr>",
        mode = { "n", "v" }, desc = "CodeCompanion New Chat",
      },
      {
        "<leader>ac", "<cmd>CodeCompanionChat Toggle<cr>",
        mode = { "n", "v" }, desc = "CodeCompanion Toggle",
      },
    },
    opts = {
      display = {
        provider = "snacks",
      },
      adapters = {
        http = {
          deepseek = function()
            return require("codecompanion.adapters").extend("deepseek", {
              env = {
                api_key = {{ (keepassxc "AI/deepseek").Password | quote }},
              },
            })
          end,
          opts = {
            show_presets = false,
          }
        },
        acp = {
          claude_code = function()
            return require("codecompanion.adapters").extend("claude_code", {})
          end,
          opts = {
            show_presets = false,
          },
        }
      },
      interactions = {
        cli = {
          agent = "claude_code",
          agents = {
            claude_code = {
              cmd = "claude",
              args = {},
              descrption = "Claude Code CLI",
            }
          }
        },
        inline = {
          adapter = "deepseek",
        },
        chat = {
          adapter = "claude_code",
        },
      },
    },
    dependencies = {
      "nvim-lua/plenary.nvim",
    }
  }
}
